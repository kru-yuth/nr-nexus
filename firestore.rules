rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user has a specific role in their roles array
    function hasRole(role) {
      return isAuthenticated() && 
             role in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles;
    }

    // Check if user is an Admin
    function isAdmin() {
      return hasRole('admin');
    }

    // Check if user is a Teacher
    function isTeacher() {
      return hasRole('teacher') || isAdmin();
    }

    // --- Rules ---

    // Unified Users Collection
    match /users/{userId} {
      // Users can read their own profile, Admins/Teachers can read all
      allow read: if isAuthenticated() && (request.auth.uid == userId || isTeacher());
      
      // Only Admins can create/delete/update users
      // Note: We might allow users to update certain fields of their own profile later
      allow write: if isAdmin();
    }

    // Volunteer Jobs Collection
    match /volunteer_jobs/{jobId} {
      allow read: if isAuthenticated();
      // Only Admins and Teachers can manage jobs
      allow write: if isTeacher();
    }

    // Configurations/Allowed Domains
    match /allowed_domains/{domain} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Generic match for any other collections (Global Deny or specific rules)
    // Deprecated collections like 'teachers' or 'students' will fall here
    match /teachers/{docId} { allow read, write: if false; }
    match /students/{docId} { allow read, write: if false; }
  }
}
