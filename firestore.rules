rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check roles in the 'users' collection
    function hasRole(role) {
      let data = getUserData();
      return request.auth != null && data != null && (
        role in data.get('roles', []) ||
        data.get('role', '') == role ||
        data.get('Role', '') == role
      );
    }

    // Helper to check for specific permissions
    function hasPermission(perm) {
      let data = getUserData();
      return request.auth != null && data != null && 
             perm in data.get('permissions', []);
    }

    // Helper to check if the user is active
    function isActive() {
      let data = getUserData();
      return request.auth != null && data != null && 
             data.get('status', 'active') == 'active';
    }
    
    // Improved Identity Helper with 3 Patterns
    // Returns the current user's profile document data
    function getUserData() {
      let by_uid = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(by_uid) ? get(by_uid).data 
           : (request.auth.token != null && 'email' in request.auth.token) ? (
               exists(/databases/$(database)/documents/users/$(request.auth.token.email.replace('@', '_').replace('.', '_'))) ?
               get(/databases/$(database)/documents/users/$(request.auth.token.email.replace('@', '_').replace('.', '_'))).data : null
             )
           : null;
    }

    // Helper function to check if requester is the homeroom teacher of the student
    function isHomeroomTeacherOf(studentData) {
      let teacherData = getUserData();
      return teacherData != null &&
             teacherData.get('homeroomClass', '') != '' &&
             studentData.get('level', '') != '' &&
             studentData.get('class', '') != '' &&
             teacherData.get('homeroomClass', '') == (studentData.get('level', '') + '/' + studentData.get('class', ''));
    }

    // Helper function to check if user has access to a CareCase
    function canAccessCase(caseData) {
      return request.auth != null && (
        hasRole('admin') ||
        hasRole('teacher') ||
        caseData.studentId == request.auth.uid ||
        request.auth.uid in caseData.get('sharedWith', [])
      );
    }

    // Users Collection
    match /users/{userId} {
      // Identity Check: Check if this document belongs to the requester using 3 patterns
      function isOwner() {
        return request.auth != null && (
          request.auth.uid == userId || // Pattern 1: Doc ID is UID
          (
            request.auth.token != null && 'email' in request.auth.token && (
              userId == request.auth.token.email.replace('@', '_').replace('.', '_') || // Pattern 2: Doc ID is Email-key
              resource.data.get('email', '') == request.auth.token.email // Pattern 3b: email field inside doc
            )
          ) ||
          resource.data.get('uid', '') == request.auth.uid // Pattern 3: uid field inside doc
        );
      }


      allow get: if request.auth != null && (
        isOwner() ||
        hasRole('admin') ||
        hasPermission('discipline.read') ||
        hasPermission('discipline.write') ||
        hasPermission('attendance.read') ||
        (hasRole('teacher') && (
          resource.data.get('roles', []).hasAny(['teacher', 'admin']) ||
          resource.data.get('role', '') == 'teacher' ||
          resource.data.get('Role', '') == 'teacher' ||
          isHomeroomTeacherOf(resource.data)
        ))
      );
      
      allow list: if request.auth != null && (
        hasRole('admin') ||
        (hasRole('teacher') && isHomeroomTeacherOf(resource.data)) ||
        hasPermission('discipline.write') ||
        hasPermission('discipline.read') ||
        hasPermission('attendance.read') ||
        (
          (request.auth.token != null && 'email' in request.auth.token && (
            resource.data.get('email', '') == request.auth.token.email || 
            resource.data.get('Email', '') == request.auth.token.email
          )) ||
          resource.data.get('uid', '') == request.auth.uid
        )
      );
      
      allow create, update: if request.auth != null && (
        isOwner() || 
        hasRole('admin')
      );
      
      allow update: if hasRole('admin') || (isOwner() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['permissions', 'roles']));
      allow delete: if hasRole('admin');
    }

    // late_checkins and behavior_scores
    match /late_checkins/{docId} {
      allow read: if request.auth != null && (
        (resource != null && (resource.data.studentId == request.auth.uid || resource.data.uid == request.auth.uid)) ||
        hasRole('admin') || 
        hasRole('teacher') ||
        hasPermission('discipline.write') ||
        hasPermission('discipline.read')
      );
      
      allow create: if request.auth != null && 
                    (request.resource.data.studentId == request.auth.uid || request.resource.data.uid == request.auth.uid) &&
                    request.resource.data.checkInTime == request.time &&
                    request.resource.data.recordedBy == 'self' &&
                    docId == request.auth.uid + "_" + request.resource.data.date;
                    
      allow create: if (hasRole('admin') || hasPermission('discipline.write')) && request.resource.data.recordedBy == 'discipline';
      allow update, delete: if hasRole('admin') || hasPermission('discipline.write');
    }

    // NR-Nexus: Attendance System - Subject Management
    match /subjects/{subjectId} {
      allow read: if request.auth != null && (
        hasRole('admin') ||
        hasRole('teacher') ||
        hasPermission('attendance.read') ||
        hasPermission('attendance.write')
      );
      allow create, update, delete: if request.auth != null && (
        hasRole('admin') ||
        hasRole('teacher') ||
        hasPermission('attendance.write')
      );
    }

    // NR-Nexus: Attendance System - Sessions & Records
    match /attendance_sessions/{sessionId} {
      allow read: if request.auth != null && (
        hasRole('admin') ||
        hasRole('teacher') ||
        hasPermission('attendance.read') ||
        hasPermission('attendance.write')
      );
      allow create, update, delete: if request.auth != null && (
        hasRole('admin') ||
        hasRole('teacher') ||
        hasPermission('attendance.write')
      );
    }

    match /attendance_records/{recordId} {
      allow read: if request.auth != null && (
        hasRole('admin') ||
        hasRole('teacher') ||
        hasPermission('attendance.read') ||
        hasPermission('attendance.write') ||
        (resource != null && (resource.data.studentId == request.auth.uid || resource.data.uid == request.auth.uid))
      );
      allow create, update, delete: if request.auth != null && (
        hasRole('admin') ||
        hasRole('teacher') ||
        hasPermission('attendance.write')
      );
    }

    match /behavior_scores/{userId} {
      function isScoreOwner(uid) {
        return request.auth != null && (request.auth.uid == uid || resource.data.uid == request.auth.uid);
      }

      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        isScoreOwner(userId) ||
        hasRole('admin') || 
        hasRole('teacher') ||
        hasPermission('discipline.write') ||
        hasPermission('discipline.read')
      );
      
      allow create: if request.auth != null && (request.auth.uid == userId || request.resource.data.uid == request.auth.uid)
                    && request.resource.data.currentScore <= 100
                    && request.resource.data.currentScore >= 0
                    && request.resource.data.updatedAt == request.time;
                    
      allow update: if isScoreOwner(userId)
                    && request.resource.data.currentScore <= 100
                    && request.resource.data.currentScore >= 0
                    && request.resource.data.updatedAt == request.time;
      
      allow write: if hasRole('admin') || hasPermission('discipline.write');

      match /history/{logId} {
        allow read: if request.auth != null && (
          request.auth.uid == userId || 
          isScoreOwner(userId) ||
          hasRole('admin') || 
          hasRole('teacher') ||
          hasPermission('discipline.write') ||
          hasPermission('discipline.read')
        );
        allow create: if request.auth != null && (request.auth.uid == userId || hasRole('admin') || hasPermission('discipline.write'));
        allow update, delete: if hasRole('admin') || hasPermission('discipline.write');
      }
    }

    // Default other modules
    match /volunteer_jobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if hasRole('admin') || hasRole('teacher');
    }

    match /volunteer_applications/{appId} {
      allow read: if request.auth != null && (
        (resource != null && (resource.data.studentId == request.auth.uid || resource.data.uid == request.auth.uid)) ||
        hasRole('admin') || hasRole('teacher')
      );
      allow create: if request.auth != null && 
                    (request.resource.data.studentId == request.auth.uid || request.resource.data.uid == request.auth.uid);
      allow update, delete: if hasRole('admin') || hasRole('teacher');
    }

    match /electricity_records/{recordId} {
      allow read: if true;
      allow create: if request.auth != null && isActive();
      allow update, delete: if hasRole('admin') || (resource.data.created_by == request.auth.uid);
    }

    match /waste_records/{recordId} {
      allow read: if true;
      allow create: if request.auth != null && isActive();
      allow update, delete: if hasRole('admin') || (resource.data.created_by == request.auth.uid);
    }

    // Student Care Module: sdqTokens
    match /sdqTokens/{token} {
      allow get: if request.auth != null || (
                    resource.data.expiresAt > request.time &&
                    resource.data.get('usedAt', null) == null
                  );
      allow create: if request.auth != null && (hasRole('admin') || hasRole('teacher'));
      allow update: if (request.auth != null && (hasRole('admin') || hasRole('teacher'))) ||
                    (resource.data.expiresAt > request.time &&
                     resource.data.get('usedAt', null) == null &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedAt']) &&
                     request.resource.data.usedAt == request.time);
      allow delete: if request.auth != null && (hasRole('admin') || hasRole('teacher'));
    }

    // Student Care Module: careCases
    match /careCases/{caseId} {
      allow read: if canAccessCase(resource.data);
      allow write: if request.auth != null && (hasRole('admin') || hasRole('teacher'));
    }

    // Student Care Module: sdqAssessments
    match /sdqAssessments/{sdqId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.studentId ||
        isHomeroomTeacherOf(get(/databases/$(database)/documents/users/$(resource.data.studentId)).data) ||
        (resource.data.careCaseId != null &&
         canAccessCase(get(/databases/$(database)/documents/careCases/$(resource.data.careCaseId)).data)) ||
        hasRole('admin')
      );

      allow create: if (request.auth != null && (
        (request.resource.data.informantType == 'student' &&
         request.auth.uid == request.resource.data.studentId) ||
        (request.resource.data.informantType == 'teacher' &&
         isHomeroomTeacherOf(get(/databases/$(database)/documents/users/$(request.resource.data.studentId)).data))
      ) && request.resource.data.completedBy == request.auth.uid) || (request.resource.data.completedBy == 'parent_token');

      allow update: if request.auth != null && (
        isHomeroomTeacherOf(get(/databases/$(database)/documents/users/$(resource.data.studentId)).data) ||
        hasRole('admin')
      ) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['careCaseId', 'updatedAt']);

      allow delete: if hasRole('admin');
    }

    // Student Care Module: homeVisits
    match /homeVisits/{visitId} {
      allow read: if request.auth != null && (
        hasRole('admin') || 
        hasRole('teacher') || 
        resource.data.studentId == request.auth.uid
      );
      allow create, update, delete: if request.auth != null && (hasRole('admin') || hasRole('teacher'));
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
